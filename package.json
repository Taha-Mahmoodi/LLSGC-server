{
  "name": "llsgc-server",
  "version": "0.1.2",
  "description": "Live Local Servers GUI Controller — local Node agent + browser UI. Same control panel as LLSGC, runs as a service and opens in any browser.",
  "author": {
    "name": "Taha Mahmoodi",
    "url": "https://github.com/Taha-Mahmoodi"
  },
  "license": "MIT",
  "homepage": "https://github.com/Taha-Mahmoodi/LLSGC-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taha-Mahmoodi/LLSGC-server.git"
  },
  "bin": {
    "llsgc-server": "./dist/server/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SRV,WEB -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "build:sea": "npm run build:client && node scripts/build-sea.mjs",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "open": "^10.1.0",
    "pidusage": "^4.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pidusage": "^2.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "zustand": "^5.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
